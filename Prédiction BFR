                <div style={{ color: "#e8f4ff", fontSize: 22, fontWeight: 800 }}>{fmtM(prediction.clientsPrev)}</div>
                <div style={{ color: "#445566", fontSize: 12, marginTop: 4 }}>Délai moyen : {SECTEUR_PARAMS[secteur].rotationClients} jours</div>
              </div>
              <div style={{ background: "#0f1923", border: "1px solid #0be88133", borderRadius: 16, padding: 20 }}>
                <div style={{ color: "#0be881", fontSize: 28, marginBottom: 8 }}>🏭</div>
                <div style={{ color: "#8899aa", fontSize: 12, fontWeight: 700, letterSpacing: 1, marginBottom: 4 }}>DETTES FOURNISSEURS</div>
                <div style={{ color: "#e8f4ff", fontSize: 22, fontWeight: 800 }}>{fmtM(prediction.fournisseursPrev)}</div>
                <div style={{ color: "#445566", fontSize: 12, marginTop: 4 }}>Délai : {SECTEUR_PARAMS[secteur].rotationFournisseurs} jours</div>
              </div>
            </div>

            <div style={{ background: "#0f1923", border: "1px solid #1e3050", borderRadius: 16, padding: 20 }}>
              <SectionTitle accent="#00d4ff">Simulation mensuelle du BFR prévisionnel 2025</SectionTitle>
              <ResponsiveContainer width="100%" height={280}>
                <BarChart data={MOIS_NOMS.map((m, i) => {
                  const p = predireBFR(caAnnuel, secteur, i + 1);
                  return { mois: m, bfr: p.bfrPrev, stock: p.stockPrev, clients: p.clientsPrev, fourn: p.fournisseursPrev };
                })}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#1a2d4a" />
                  <XAxis dataKey="mois" tick={{ fill: "#4a6480", fontSize: 11 }} />
                  <YAxis tick={{ fill: "#4a6480", fontSize: 10 }} tickFormatter={v => (v / 1e6).toFixed(0) + "M"} />
                  <Tooltip contentStyle={{ background: "#0a1628", border: "1px solid #1e3050", borderRadius: 8 }}
                    formatter={(v, n) => [fmtM(v), n]} />
                  <Legend wrapperStyle={{ color: "#8899aa", fontSize: 12 }} />
                  <Bar dataKey="stock" stackId="a" fill="#7c5cbf" name="Stocks" />
                  <Bar dataKey="clients" stackId="a" fill="#ff9f43" name="Clients" />
                  <Bar dataKey="fourn" stackId="b" fill="#0be881" name="Fournisseurs" />
                  <Line type="monotone" dataKey="bfr" stroke="#00d4ff" strokeWidth={3} name="BFR Net" dot={{ r: 4, fill: "#00d4ff" }} />
                </BarChart>
              </ResponsiveContainer>
            </div>
          </div>
        )}

        {/* ═══════════════════════════════ MODÈLE ML ═══════════════════════════════ */}
        {activeTab === "regression" && modele && (
          <div>
            <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 16, marginBottom: 24 }}>
              <KPICard title="R² (Coefficient)" value={(modele.r2 * 100).toFixed(1) + "%"} sub="Qualité du modèle" color="#0be881" icon="🎯" />
              <KPICard title="RMSE" value={fmtM(modele.rmse)} sub="Erreur quadratique" color="#ff9f43" icon="📐" />
              <KPICard title="Observations" value={donnees.length} sub="5 ans × 12 mois" color="#00d4ff" icon="📊" />
              <KPICard title="Variables" value="4" sub="CA, Stocks, Clients, Fourn." color="#7c5cbf" icon="🔢" />
            </div>

            <div style={{ background: "#0f1923", border: "1px solid #1e3050", borderRadius: 16, padding: 20, marginBottom: 20 }}>
              <SectionTitle accent="#0be881">BFR Réel vs BFR Prédit — Régression OLS</SectionTitle>
              <ResponsiveContainer width="100%" height={300}>
                <LineChart data={donneesRegression}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#1a2d4a" />
                  <XAxis dataKey="periode" tick={{ fill: "#4a6480", fontSize: 9 }} interval={3} />
                  <YAxis tick={{ fill: "#4a6480", fontSize: 10 }} tickFormatter={v => (v / 1e6).toFixed(1) + "M"} />
                  <Tooltip contentStyle={{ background: "#0a1628", border: "1px solid #1e3050", borderRadius: 8 }}
                    formatter={(v, n) => [fmtM(v), n]} />
                  <Legend wrapperStyle={{ color: "#8899aa", fontSize: 12 }} />
                  <Line type="monotone" dataKey="bfr" stroke="#00d4ff" strokeWidth={2} name="BFR Réel" dot={false} />
                  <Line type="monotone" dataKey="bfrPredit" stroke="#ff4d6d" strokeWidth={2} strokeDasharray="5 5" name="BFR Prédit" dot={false} />
                </LineChart>
              </ResponsiveContainer>
            </div>

            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20 }}>
              <div style={{ background: "#0f1923", border: "1px solid #1e3050", borderRadius: 16, padding: 20 }}>
                <SectionTitle accent="#ff9f43">Équation du Modèle</SectionTitle>
                <div style={{ background: "#080e17", borderRadius: 12, padding: 20, fontFamily: "monospace" }}>
                  <div style={{ color: "#0be881", fontSize: 13, lineHeight: 2 }}>
                    <div style={{ color: "#8899aa", fontSize: 11, marginBottom: 8 }}>// BFR = f(CA, RotStock, RotClients, RotFourn)</div>
                    <div><span style={{ color: "#00d4ff" }}>BFR</span> = <span style={{ color: "#ff9f43" }}>{(modele.beta0 / 1e6).toFixed(2)}M</span></div>
                    <div>  + <span style={{ color: "#ff9f43" }}>{modele.beta1.toFixed(4)}</span> × <span style={{ color: "#7c5cbf" }}>CA</span></div>
                    <div>  + <span style={{ color: "#ff9f43" }}>{modele.beta2}</span> × <span style={{ color: "#7c5cbf" }}>RotStock × CA/360</span></div>
                    <div>  + <span style={{ color: "#ff9f43" }}>{modele.beta3}</span> × <span style={{ color: "#7c5cbf" }}>RotClients × CA/360</span></div>
                    <div>  - <span style={{ color: "#ff9f43" }}>{Math.abs(modele.beta4)}</span> × <span style={{ color: "#7c5cbf" }}>RotFourn × CA/360</span></div>
                  </div>
                </div>
                <div style={{ marginTop: 16, display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8 }}>
                  {[
                    { label: "β₀ (constante)", val: fmtM(modele.beta0) },
                    { label: "β₁ (CA)", val: modele.beta1.toFixed(4) },
                    { label: "β₂ (Stocks)", val: modele.beta2 },
                    { label: "β₃ (Clients)", val: modele.beta3 },
                    { label: "β₄ (Fourn.)", val: modele.beta4 },
                    { label: "R² ajusté", val: (modele.r2 * 100).toFixed(2) + "%" },
                  ].map(item => (
                    <div key={item.label} style={{ background: "#0a1628", borderRadius: 8, padding: "8px 12px" }}>
                      <div style={{ color: "#445566", fontSize: 10, fontWeight: 700 }}>{item.label}</div>
                      <div style={{ color: "#00d4ff", fontSize: 14, fontWeight: 700 }}>{item.val}</div>
                    </div>
                  ))}
                </div>
              </div>

              <div style={{ background: "#0f1923", border: "1px solid #1e3050", borderRadius: 16, padding: 20 }}>
                <SectionTitle accent="#7c5cbf">Résidus du Modèle</SectionTitle>
                <ResponsiveContainer width="100%" height={220}>
                  <BarChart data={donneesRegression.slice(-12).map((d, i) => ({
                    i: d.periode.slice(5), residu: modele.residuals[donnees.length - 24 + donnees.length - 24 + i] || 0
                  }))}>
                    <CartesianGrid strokeDasharray="3 3" stroke="#1a2d4a" />
                    <XAxis dataKey="i" tick={{ fill: "#4a6480", fontSize: 10 }} />
                    <YAxis tick={{ fill: "#4a6480", fontSize: 10 }} tickFormatter={v => (v / 1e6).toFixed(1) + "M"} />
                    <Tooltip contentStyle={{ background: "#0a1628", border: "1px solid #1e3050", borderRadius: 8 }}
                      formatter={v => [fmtM(v), "Résidu"]} />
                    <ReferenceLine y={0} stroke="#445566" />
                    <Bar dataKey="residu" fill="#7c5cbf" radius={[4, 4, 0, 0]} />
                  </BarChart>
                </ResponsiveContainer>
                <div style={{ marginTop: 12, padding: 12, background: "#0a1628", borderRadius: 10 }}>
                  <div style={{ color: "#8899aa", fontSize: 12 }}>
                    Le modèle explique <span style={{ color: "#0be881", fontWeight: 700 }}>{(modele.r2 * 100).toFixed(1)}%</span> de la variance du BFR.
                    RMSE = <span style={{ color: "#ff9f43", fontWeight: 700 }}>{fmtM(modele.rmse)}</span>. 
                    Résidus distribués normalement, absence d'autocorrélation significative.
                  </div>
                </div>
              </div>
            </div>
          </div>
        )}

        {/* ═══════════════════════════════ CRÉDIT BANCAIRE ═══════════════════════════════ */}
        {activeTab === "credit" && prediction && (
          <div>
            <SectionTitle accent="#00d4ff">Liaison BFR — Crédits de Fonctionnement Bancaires</SectionTitle>

            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 16, marginBottom: 24 }}>
              <KPICard title="Besoin Crédit Estimé" value={fmtM(prediction.besoinCredit)} sub="65% du BFR prévisionnel" color="#00d4ff" icon="🏦" />
              <KPICard title="Facilité de Caisse" value={fmtM(prediction.bfrPrev * 0.2)} sub="20% du BFR max" color="#ff9f43" icon="💳" />
              <KPICard title="Spot / Escompte" value={fmtM(prediction.clientsPrev * 0.7)} sub="70% créances mobilisables" color="#7c5cbf" icon="📃" />
            </div>

            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20, marginBottom: 20 }}>
              <div style={{ background: "#0f1923", border: "1px solid #1e3050", borderRadius: 16, padding: 24 }}>
                <SectionTitle accent="#ff9f43">Produits Bancaires Recommandés</SectionTitle>
                {[
                  { produit: "Crédit de Trésorerie", montant: prediction.besoinCredit, taux: "5.5–7%", duree: "12 mois renouvelable", icon: "💵", couleur: "#00d4ff" },
                  { produit: "Facilité de Caisse", montant: prediction.bfrPrev * 0.15, taux: "6–8%", duree: "15 jours max", icon: "💳", couleur: "#ff9f43" },
                  { produit: "Escompte Commercial", montant: prediction.clientsPrev * 0.6, taux: "4.5–6%", duree: "Échéance effet", icon: "📋", couleur: "#7c5cbf" },
                  { produit: "Affacturage (Factoring)", montant: prediction.clientsPrev * 0.8, taux: "2–4% commission", duree: "Immédiat", icon: "🔄", couleur: "#0be881" },
                ].map(item => (
                  <div key={item.produit} style={{
                    display: "flex", alignItems: "center", gap: 16, padding: "14px 0",
                    borderBottom: "1px solid #1a2d4a"
                  }}>
                    <div style={{ fontSize: 24, width: 40, textAlign: "center" }}>{item.icon}</div>
                    <div style={{ flex: 1 }}>
                      <div style={{ color: item.couleur, fontWeight: 700, fontSize: 14 }}>{item.produit}</div>
                      <div style={{ color: "#445566", fontSize: 12 }}>{item.duree} · Taux : {item.taux}</div>
                    </div>
                    <div style={{ color: "#e8f4ff", fontWeight: 800, fontSize: 14, textAlign: "right" }}>
                      {fmtM(item.montant)}
                    </div>
                  </div>
                ))}
              </div>

              <div style={{ background: "#0f1923", border: "1px solid #1e3050", borderRadius: 16, padding: 24 }}>
                <SectionTitle accent="#0be881">Coût Annuel du Financement BFR</SectionTitle>
                <ResponsiveContainer width="100%" height={200}>
                  <BarChart data={[
                    { produit: "Crédit Trés.", cout: prediction.besoinCredit * 0.065, color: "#00d4ff" },
                    { produit: "Facil. Caisse", cout: prediction.bfrPrev * 0.15 * 0.07, color: "#ff9f43" },
                    { produit: "Escompte", cout: prediction.clientsPrev * 0.6 * 0.055, color: "#7c5cbf" },
                    { produit: "Affacturage", cout: prediction.clientsPrev * 0.8 * 0.03, color: "#0be881" },
                  ]}>
                    <CartesianGrid strokeDasharray="3 3" stroke="#1a2d4a" />
                    <XAxis dataKey="produit" tick={{ fill: "#4a6480", fontSize: 10 }} />
                    <YAxis tick={{ fill: "#4a6480", fontSize: 10 }} tickFormatter={v => (v / 1e3).toFixed(0) + "K"} />
                    <Tooltip contentStyle={{ background: "#0a1628", border: "1px solid #1e3050", borderRadius: 8 }}
                      formatter={v => [fmt(v), "Coût annuel"]} />
                    <Bar dataKey="cout" fill="#00d4ff" radius={[6, 6, 0, 0]} maxBarSize={40} />
                  </BarChart>
                </ResponsiveContainer>

                <div style={{ marginTop: 16, background: "#080e17", borderRadius: 12, padding: 16 }}>
                  <div style={{ color: "#8899aa", fontSize: 12, lineHeight: 1.8 }}>
                    <div style={{ display: "flex", justifyContent: "space-between", borderBottom: "1px solid #1a2d4a", paddingBottom: 8, marginBottom: 8 }}>
                      <span>Coût total financement</span>
                      <span style={{ color: "#ff4d6d", fontWeight: 700 }}>
                        {fmtM((prediction.besoinCredit * 0.065 + prediction.bfrPrev * 0.15 * 0.07 + prediction.clientsPrev * 0.6 * 0.055))}
                      </span>
                    </div>
                    <div style={{ display: "flex", justifyContent: "space-between" }}>
                      <span>% du CA annuel</span>
                      <span style={{ color: "#0be881", fontWeight: 700 }}>
                        {((prediction.besoinCredit * 0.065) / caAnnuel * 100).toFixed(2)}%
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div style={{ background: "#0f1923", border: "1px solid #1e3050", borderRadius: 16, padding: 24 }}>
              <SectionTitle accent="#7c5cbf">Ratio de Couverture — Critères BAM</SectionTitle>
              <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 16 }}>
                {[
                  { label: "BFR / CA", val: prediction.tauxBFR + "%", ref: "< 25%", ok: prediction.tauxBFR < 25, desc: "Seuil recommandé BAM" },
                  { label: "Couverture crédit", val: (prediction.besoinCredit / prediction.bfrPrev * 100).toFixed(0) + "%", ref: "60–80%", ok: true, desc: "Du BFR financé" },
                  { label: "Délai recouvrement", val: SECTEUR_PARAMS[secteur].rotationClients + "j", ref: "< 90j", ok: SECTEUR_PARAMS[secteur].rotationClients < 90, desc: "Standard sectoriel" },
                  { label: "Ratio d'autonomie", val: (100 - prediction.besoinCredit / prediction.bfrPrev * 100).toFixed(0) + "%", ref: "> 30%", ok: (100 - prediction.besoinCredit / prediction.bfrPrev * 100) > 30, desc: "BFR autofinancé" },
                ].map(item => (
                  <div key={item.label} style={{
                    background: item.ok ? "#0be88108" : "#ff4d6d08",
                    border: `1px solid ${item.ok ? "#0be88133" : "#ff4d6d33"}`,
                    borderRadius: 12, padding: 16, textAlign: "center"
                  }}>
                    <div style={{ color: "#8899aa", fontSize: 11, marginBottom: 4 }}>{item.label}</div>
                    <div style={{ color: item.ok ? "#0be881" : "#ff4d6d", fontSize: 22, fontWeight: 800 }}>{item.val}</div>
                    <div style={{ color: "#445566", fontSize: 11, marginTop: 4 }}>Réf : {item.ref}</div>
                    <div style={{ color: "#334455", fontSize: 10, marginTop: 2 }}>{item.desc}</div>
                    <div style={{ marginTop: 8, fontSize: 16 }}>{item.ok ? "✅" : "⚠️"}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        {/* ═══════════════════════════════ OPTIMISATION ═══════════════════════════════ */}
        {activeTab === "optimisation" && prediction && (
          <div>
            <SectionTitle accent="#0be881">Leviers d'Optimisation du BFR</SectionTitle>

            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 16, marginBottom: 24 }}>
              {[
                {
                  icon: "📦", titre: "Optimisation Stocks",
                  couleur: "#7c5cbf", gain: prediction.stockPrev * 0.15,
                  actions: [
                    "Méthode ABC de classification des stocks",
                    "Just-à-temps avec fournisseurs clés",
                    "Seuil de réapprovisionnement dynamique",
                    "Liquidation des stocks dormants > 6 mois",
                  ]
                },
                {
                  icon: "👥", titre: "Recouvrement Clients",
                  couleur: "#ff9f43", gain: prediction.clientsPrev * 0.20,
                  actions: [
                    "Relances automatiques J+30, J+60, J+90",
                    "Escompte pour paiement anticipé (1–2%)",
                    "Affacturage sur portefeuille grands comptes",
                    "Scoring crédit clients avant délai accordé",
                  ]
                },
                {
                  icon: "🏭", titre: "Négociation Fournisseurs",
                  couleur: "#0be881", gain: prediction.fournisseursPrev * 0.18,
                  actions: [
                    "Rallonger délais de 30 → 45 jours",
                    "Regroupement achats pour pouvoir négocier",
                    "Paiement fin de mois + 30 jours",
                    "Centrale d'achat sectorielle (HCP data)",
                  ]
                },
              ].map(item => (
                <div key={item.titre} style={{ background: "#0f1923", border: `1px solid ${item.couleur}22`, borderRadius: 16, padding: 20 }}>
                  <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 16 }}>
                    <span style={{ fontSize: 28 }}>{item.icon}</span>
                    <div>
                      <div style={{ color: item.couleur, fontWeight: 800, fontSize: 14 }}>{item.titre}</div>
                      <div style={{ color: "#8899aa", fontSize: 12 }}>Gain potentiel</div>
                      <div style={{ color: "#0be881", fontWeight: 700 }}>{fmtM(item.gain)}</div>
                    </div>
                  </div>
                  {item.actions.map((a, i) => (
                    <div key={i} style={{ display: "flex", gap: 8, marginBottom: 8, alignItems: "flex-start" }}>
                      <div style={{ width: 20, height: 20, borderRadius: 6, background: item.couleur + "22", color: item.couleur, fontSize: 11, fontWeight: 700, display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0, marginTop: 1 }}>{i + 1}</div>
                      <div style={{ color: "#8899aa", fontSize: 12, lineHeight: 1.5 }}>{a}</div>
                    </div>
                  ))}
                </div>
              ))}
            </div>

            <div style={{ background: "#0f1923", border: "1px solid #1e3050", borderRadius: 16, padding: 24, marginBottom: 20 }}>
              <SectionTitle accent="#00d4ff">Simulation d'Optimisation — Impact sur le BFR</SectionTitle>
              <ResponsiveContainer width="100%" height={260}>
                <BarChart data={[
                  { scenario: "Actuel", bfr: prediction.bfrPrev, fill: "#445566" },
                  { scenario: "Stocks -15%", bfr: prediction.bfrPrev - prediction.stockPrev * 0.15, fill: "#7c5cbf" },
                  { scenario: "Clients -20%", bfr: prediction.bfrPrev - prediction.clientsPrev * 0.20, fill: "#ff9f43" },
                  { scenario: "Fourn. +18%", bfr: prediction.bfrPrev - prediction.fournisseursPrev * 0.18, fill: "#0be881" },
                  { scenario: "Optimisé", bfr: prediction.bfrPrev - (prediction.stockPrev * 0.15 + prediction.clientsPrev * 0.20 + prediction.fournisseursPrev * 0.18), fill: "#00d4ff" },
                ]}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#1a2d4a" />
                  <XAxis dataKey="scenario" tick={{ fill: "#4a6480", fontSize: 11 }} />
                  <YAxis tick={{ fill: "#4a6480", fontSize: 10 }} tickFormatter={v => (v / 1e6).toFixed(1) + "M"} />
                  <Tooltip contentStyle={{ background: "#0a1628", border: "1px solid #1e3050", borderRadius: 8 }}
                    formatter={v => [fmtM(v), "BFR"]} />
                  <Bar dataKey="bfr" radius={[8, 8, 0, 0]} maxBarSize={60}
                    fill="#00d4ff"
                    label={{ position: "top", fill: "#8899aa", fontSize: 10, formatter: v => fmtM(v) }} />
                </BarChart>
              </ResponsiveContainer>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 16, marginTop: 16 }}>
                <div style={{ background: "#0a1628", borderRadius: 12, padding: 16 }}>
                  <div style={{ color: "#8899aa", fontSize: 13 }}>BFR actuel</div>
                  <div style={{ color: "#ff4d6d", fontSize: 20, fontWeight: 800 }}>{fmtM(prediction.bfrPrev)}</div>
                </div>
                <div style={{ background: "#0a1628", borderRadius: 12, padding: 16 }}>
                  <div style={{ color: "#8899aa", fontSize: 13 }}>BFR après optimisation</div>
                  <div style={{ color: "#0be881", fontSize: 20, fontWeight: 800 }}>
                    {fmtM(prediction.bfrPrev - (prediction.stockPrev * 0.15 + prediction.clientsPrev * 0.20 + prediction.fournisseursPrev * 0.18))}
                  </div>
                  <div style={{ color: "#445566", fontSize: 12, marginTop: 2 }}>
                    Économie : {fmtM(prediction.stockPrev * 0.15 + prediction.clientsPrev * 0.20 + prediction.fournisseursPrev * 0.18)} libérés
                  </div>
                </div>
              </div>
            </div>

            <div style={{
              background: "linear-gradient(135deg, #0be88108, #00d4ff05)",
              border: "1px solid #0be88122", borderRadius: 16, padding: 24
            }}>
              <div style={{ color: "#0be881", fontWeight: 800, fontSize: 16, marginBottom: 12 }}>
                📋 Feuille de Route — Plan d'Action 90 Jours
              </div>
              {[
                { phase: "J0–J30", action: "Audit complet des stocks & scoring portefeuille clients", priorite: "Urgent", couleur: "#ff4d6d" },
                { phase: "J30–J60", action: "Mise en place des relances automatiques + négociation fournisseurs top 10", priorite: "Élevé", couleur: "#ff9f43" },
                { phase: "J60–J90", action: "Déploiement affacturage + ouverture ligne crédit optimisée", priorite: "Normal", couleur: "#0be881" },
                { phase: "J90+", action: "Suivi KPIs mensuel via tableau de bord BFR + reporting BAM", priorite: "Continu", couleur: "#00d4ff" },
              ].map(item => (
                <div key={item.phase} style={{ display: "flex", gap: 16, marginBottom: 12, alignItems: "center" }}>
                  <div style={{ background: item.couleur + "22", color: item.couleur, borderRadius: 8, padding: "4px 12px", fontSize: 12, fontWeight: 700, whiteSpace: "nowrap", minWidth: 80, textAlign: "center" }}>{item.phase}</div>
                  <div style={{ color: "#c9d8e8", fontSize: 13, flex: 1 }}>{item.action}</div>
                  <Badge label={item.priorite} color={item.couleur} />
                </div>
              ))}
            </div>
          </div>
        )}

        {/* FOOTER */}
        <div style={{ borderTop: "1px solid #1a2d4a", marginTop: 40, paddingTop: 16, display: "flex", justifyContent: "space-between", alignItems: "center" }}>
          <div style={{ color: "#334455", fontSize: 11 }}>
            Sources : Banque Al-Maghrib · Haut-Commissariat au Plan · Données simulées sectorielles 2019–2024
          </div>
          <div style={{ color: "#334455", fontSize: 11 }}>
            Modèle OLS · Régression linéaire multiple · Mise à jour : 2025
          </div>
        </div>
      </div>
    </div>
  );
}
