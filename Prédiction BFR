  "BTP & Immobilier":          { rotationStock: 90,  rotationClients: 120, rotationFournisseurs: 75, saisonnalite: 1.1, marge: 0.08 },
  "Industrie agroalimentaire": { rotationStock: 20,  rotationClients: 45,  rotationFournisseurs: 50, saisonnalite: 1.4, marge: 0.15 },
  "Textile & Habillement":     { rotationStock: 60,  rotationClients: 60,  rotationFournisseurs: 45, saisonnalite: 1.5, marge: 0.18 },
  "Services aux entreprises":  { rotationStock: 0,   rotationClients: 60,  rotationFournisseurs: 30, saisonnalite: 1.0, marge: 0.25 },
  "Transport & Logistique":    { rotationStock: 15,  rotationClients: 45,  rotationFournisseurs: 35, saisonnalite: 1.1, marge: 0.10 },
  "Hôtellerie & Tourisme":     { rotationStock: 10,  rotationClients: 20,  rotationFournisseurs: 30, saisonnalite: 2.0, marge: 0.30 },
  "Pharmacie & Santé":         { rotationStock: 40,  rotationClients: 50,  rotationFournisseurs: 45, saisonnalite: 1.1, marge: 0.22 },
};

function genererDonnees(secteur, caBase, annees = 5) {
  const params = SECTEUR_PARAMS[secteur];
  const data = [];
  for (let i = 0; i < annees * 12; i++) {
    const annee = 2019 + Math.floor(i / 12);
    const mois = (i % 12) + 1;
    const croissance = 1 + (annee - 2019) * 0.06 + (Math.random() - 0.5) * 0.04;
    const saisonFactor = 1 + (params.saisonnalite - 1) * Math.sin((mois / 12) * Math.PI * 2 - 1.5) * 0.5;
    const ca = caBase * croissance * saisonFactor * (1 + (Math.random() - 0.5) * 0.1);
    const caJour = ca / 360;
    const stock = params.rotationStock * caJour * (1 + (Math.random() - 0.5) * 0.15);
    const clients = params.rotationClients * caJour * (1 + (Math.random() - 0.5) * 0.12);
    const fournisseurs = params.rotationFournisseurs * caJour * (1 + (Math.random() - 0.5) * 0.1);
    const bfr = stock + clients - fournisseurs;
    const tauxBFR = bfr / ca;
    data.push({
      periode: `${annee}-${String(mois).padStart(2, "0")}`,
      annee, mois, ca: Math.round(ca),
      stock: Math.round(stock), clients: Math.round(clients),
      fournisseurs: Math.round(fournisseurs),
      bfr: Math.round(bfr),
      tauxBFR: parseFloat((tauxBFR * 100).toFixed(2)),
      rotStock: params.rotationStock, rotClients: params.rotationClients,
      rotFournisseurs: params.rotationFournisseurs,
    });
  }
  return data;
}

// ─────────────────────────────────────────────
// MODÈLE DE RÉGRESSION LINÉAIRE MULTIPLE
// ─────────────────────────────────────────────
function regressionMultiple(data) {
  const n = data.length;
  const X = data.map(d => [1, d.ca / 1e6, d.rotStock, d.rotClients, d.rotFournisseurs, d.mois || d.mois]);
  const Y = data.map(d => d.bfr / 1e6);
  // Moindres carrés ordinaires (OLS) simplifié
  // BFR = β0 + β1*CA + β2*RotStock + β3*RotClients + β4*RotFourn + ε
  // Approximation par corrélation directe
  const meanCA = data.reduce((s, d) => s + d.ca, 0) / n;
  const meanBFR = data.reduce((s, d) => s + d.bfr, 0) / n;
  const covCABFR = data.reduce((s, d) => s + (d.ca - meanCA) * (d.bfr - meanBFR), 0) / n;
  const varCA = data.reduce((s, d) => s + (d.ca - meanCA) ** 2, 0) / n;
  const beta1 = covCABFR / varCA;
  const beta0 = meanBFR - beta1 * meanCA;

  // Coefficients sectoriels additionnels
  const beta2 = 0.0008; // impact rotation stock
  const beta3 = 0.0012; // impact rotation clients
  const beta4 = -0.0009; // impact rotation fournisseurs

  const predictions = data.map(d => {
    const pred = beta0 + beta1 * d.ca + beta2 * d.rotStock * d.ca / 360 + beta3 * d.rotClients * d.ca / 360 + beta4 * d.rotFournisseurs * d.ca / 360;
    return Math.round(pred);
  });

  const residuals = data.map((d, i) => d.bfr - predictions[i]);
  const ssRes = residuals.reduce((s, r) => s + r ** 2, 0);
  const ssTot = data.reduce((s, d) => s + (d.bfr - meanBFR) ** 2, 0);
  const r2 = 1 - ssRes / ssTot;
  const rmse = Math.sqrt(ssRes / n);

  return { beta0, beta1, beta2, beta3, beta4, r2, rmse, predictions, residuals };
}

function predireBFR(ca, secteur, moisCible) {
  const params = SECTEUR_PARAMS[secteur];
  const caJour = ca / 360;
  const saisonFactor = 1 + (params.saisonnalite - 1) * Math.sin((moisCible / 12) * Math.PI * 2 - 1.5) * 0.5;
  const stockPrev = params.rotationStock * caJour * saisonFactor;
  const clientsPrev = params.rotationClients * caJour * saisonFactor;
  const fournisseursPrev = params.rotationFournisseurs * caJour;
  const bfrPrev = stockPrev + clientsPrev - fournisseursPrev;
  const besoinCredit = Math.max(0, bfrPrev * 0.65);
  return {
    stockPrev: Math.round(stockPrev),
    clientsPrev: Math.round(clientsPrev),
    fournisseursPrev: Math.round(fournisseursPrev),
    bfrPrev: Math.round(bfrPrev),
    besoinCredit: Math.round(besoinCredit),
    tauxBFR: parseFloat(((bfrPrev / ca) * 100).toFixed(2)),
  };
}

